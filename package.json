{
  "name": "customsite",
  "version": "1.0.0",
  "private": true,
  "description": "CustomSite agency — Express API + static site",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/**/*.test.js",
    "typecheck": "npx tsc --noEmit",
    "launch:check": "npm run typecheck && npm test && npm run build:admin",
    "deploy:railway": "npx @railway/cli@latest up",
    "admin:dev": "npx vite",
    "build": "npm run build:admin",
    "build:admin": "npx vite build && npx vite build --config vite.conversion-demo.config.ts",
    "preview:admin": "npx vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "rate-limit-redis": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "resend": "^4.0.1",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
