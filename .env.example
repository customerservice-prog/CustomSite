# Copy to .env locally; on Railway set variables in the dashboard.
# Railway: keep Supabase/Stripe keys as *runtime* variables only. Do not attach them
# to the Docker "build" phase (avoids them ending up in build ARG/ENV and linter warnings).

# Public site (exactly one hostname; use www or not — this drives canonical redirects so
# login on www and non-www share the same localStorage. Omit on Railway if you use only
# the default *.railway.app URL for tests.)
# SKIP_CANONICAL_HOST=1
PUBLIC_SITE_URL=https://customsite.online

# Comma-separated emails that get role=admin when their public.users row is first created
# BOOTSTRAP_ADMIN_EMAILS=you@yourdomain.com

# Calendly — 20-minute booking URL (required for “Book a call” buttons site-wide)
CALENDLY_20_MIN=

# Email (Resend) — https://resend.com
RESEND_API_KEY=
# Use your verified Resend domain in production, e.g. hello@customsite.online
FROM_EMAIL=hello@customsite.online
ADMIN_EMAIL=hello@customsite.online

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Database
# (Supabase keys are usually in lib/env or Railway per your setup)

# Vite / admin SPA (local dev: copy this file to `.env` and uncomment)
# Use the live Express `/api` + Supabase from the browser (same origin as Vite proxy).
# Without this, the admin uses the in-memory demo dataset; Site builder files use localStorage.
# VITE_USE_REAL_API=1
#
# Production builds load committed `.env.production` (real API on by default). Override locally only if needed:
# VITE_HIDE_DEMO_BANNER=1

# --- Railway: one-click client site deploy (Issue #18) ---
# Create a token at https://railway.com/account/tokens (use an account or team token that
# can create projects and services — not only a per-project deploy token).
# On Railway hosting *this* CustomSite app: Project → your CustomSite service → Variables → add:
#
#   RAILWAY_API_TOKEN=<paste token>
#   RAILWAY_TEAM_ID=<workspace/team UUID from Railway (GraphiQL me { teams { edges { node { id } } } } or dashboard)>
#
# Redeploy the CustomSite service after saving variables. Then POST /api/admin/projects/:id/deploy
# (Deploy production in the UI) can auto-provision a new Railway project, upload the static bundle,
# and store railway_url_production. Optional: RAILWAY_UP_TIMEOUT_MS (default 720000 = 12 minutes).
#
# RAILWAY_API_TOKEN=
# RAILWAY_TEAM_ID=
# RAILWAY_UP_TIMEOUT_MS=720000

# Optional: comma-separated hostnames that always get the platform (marketing + admin), never client-site routing.
# CUSTOMSITE_PLATFORM_HOSTS=app.example.com,www.example.com
# Optional: cache TTL for Host → project_id lookup in ms (default 120000).
# CUSTOMSITE_DOMAIN_CACHE_MS=120000
#
# Emergency: hostname → UUID when DNS is live but DB custom_domain missing/typo. Comma-separated host|uuid pairs (apex hostname, normalized).
# CUSTOMSITE_DOMAIN_PROJECT_MAP=cestuiquevietrust.com|55546683-c4f1-419c-a2d4-b35378679537
#
# Ingress hostname resolution (client sites): X-Forwarded-Host, else RFC 7239 Forwarded host=, else Host — reliable behind Cloudflare → Railway.

# --- YouTube library: archive & fallback (cestui-style sites) ---
# Supabase Storage bucket must exist and be readable for playback (prefer public READ on `video-archive`).
# OPTIONAL: CUSTOMSITE_VIDEO_ARCHIVE_BUCKET=video-archive
# Railway Docker image installs ffmpeg + yt-dlp; optionally override binary paths:
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg
#
# Cron: VIDEO_ARCHIVE_CRON_ENABLED=1 on the Express service runs runArchiveCycle on a schedule (default 04:00 UTC).
# VIDEO_ARCHIVE_CRON=0 4 * * *
# Or Railway Cron calls: node scripts/archive-videos.js (same vars as runtime).
#
# VIDEO_ARCHIVE_CHECK_ONLY=0
# VIDEO_ARCHIVE_ROW_LIMIT=
# VIDEO_ARCHIVE_DOWNLOAD_LIMIT=
# VIDEO_ARCHIVE_DOWNLOAD_TIMEOUT_MS=1200000
# VIDEO_ARCHIVE_TMP=
# VIDEO_ARCHIVE_YT_FORMAT=bestvideo[height<=720][ext=mp4]+bestaudio[ext=m4a]/best[height<=720][ext=mp4]/best[height<=720]
# VIDEO_ARCHIVE_EMAIL_ALERT=0
# OPTIONAL: VIDEO_ARCHIVE_SYNC_SECRET=<random>; POST /api/videos/sync also accepts Authorization: Bearer <admin JWT> or x-cron-secret: CRON_SECRET
# VIDEO_ARCHIVE_SEED_PATH=data/cestui-videos.seed.json
# VIDEO_ARCHIVE_LIST_RATELIMIT_MAX=120
