# Copy to .env locally; on Railway set variables in the dashboard.

# Public site (exactly one hostname; use www or not — this drives canonical redirects so
# login on www and non-www share the same localStorage. Omit on Railway if you use only
# the default *.railway.app URL for tests.)
# SKIP_CANONICAL_HOST=1
PUBLIC_SITE_URL=https://customsite.online

# Comma-separated emails that get role=admin when their public.users row is first created
# BOOTSTRAP_ADMIN_EMAILS=you@yourdomain.com

# Calendly — 20-minute booking URL (required for “Book a call” buttons site-wide)
CALENDLY_20_MIN=

# Email (Resend) — https://resend.com
RESEND_API_KEY=
# Use your verified Resend domain in production, e.g. hello@customsite.online
FROM_EMAIL=hello@customsite.online
ADMIN_EMAIL=hello@customsite.online

# Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Database
# (Supabase keys are usually in lib/env or Railway per your setup)
