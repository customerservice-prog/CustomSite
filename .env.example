# Server
PORT=3000
PUBLIC_SITE_URL=https://customsite.online

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key (Dashboard → API). Alias: SUPABASE_SERVICE_KEY
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time build checkout — create Products/Prices in Stripe and paste Price IDs
STRIPE_PRICE_BUILD_STARTER=
STRIPE_PRICE_BUILD_BUSINESS=
STRIPE_PRICE_BUILD_ECOMMERCE=
# Optional: maintenance subscriptions (monthly) — for /api/payments/create-subscription
STRIPE_PRICE_MAINT_STARTER_MONTHLY=
STRIPE_PRICE_MAINT_BUSINESS_MONTHLY=
STRIPE_PRICE_MAINT_ECOMMERCE_MONTHLY=

# Email (https://resend.com)
RESEND_API_KEY=
ADMIN_EMAIL=
FROM_EMAIL=

# Optional: custom session signing (reserved for future use)
JWT_SECRET=
