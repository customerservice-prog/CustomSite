# Server
PORT=3000
# E.164 public phone (used on local-SEO host landings: JSON-LD, nav, tel:). Optional display override.
# SITE_PHONE=+13155550100
# SITE_PHONE_DISPLAY=(315) 555-0100
# Use this site URL to derive a single CORS allow-origin when CORS_ORIGINS is unset
PUBLIC_SITE_URL=https://customsite.online
# Comma- or semicolon-separated extra origins (overrides single-origin from PUBLIC_SITE_URL)
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# Optional: shared rate-limit store for POST /api/contact (multiple Railway instances)
# REDIS_URL=rediss://default:pass@host:6379

# Local sign-in when Supabase is not configured (development only; never enable in public production
# without understanding the risk; use ALLOW_PROD_DEV_AUTH=1 to force, not recommended)
DEV_AUTH=1
DEV_AUTH_SECRET=replace-with-random-64-hex
DEV_ADMIN_EMAIL=admin@local.dev
DEV_ADMIN_PASSWORD=LocalDev2026

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key (Dashboard → API). Alias: SUPABASE_SERVICE_KEY
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails that get role=admin on first sign-in (auto-created public.users row)
# BOOTSTRAP_ADMIN_EMAILS=ops@yoursite.com,founder@yoursite.com
# INITIAL_ADMIN_EMAIL=ops@yoursite.com

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time build checkout — create Products/Prices in Stripe and paste Price IDs
STRIPE_PRICE_BUILD_STARTER=
STRIPE_PRICE_BUILD_BUSINESS=
STRIPE_PRICE_BUILD_ECOMMERCE=
# Optional: maintenance subscriptions (monthly) — for /api/payments/create-subscription
STRIPE_PRICE_MAINT_STARTER_MONTHLY=
STRIPE_PRICE_MAINT_BUSINESS_MONTHLY=
STRIPE_PRICE_MAINT_ECOMMERCE_MONTHLY=

# Email (https://resend.com)
RESEND_API_KEY=
ADMIN_EMAIL=
FROM_EMAIL=

# Optional: custom session signing (reserved for future use)
JWT_SECRET=
